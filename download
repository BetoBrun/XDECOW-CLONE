# -*- coding: utf-8 -*-
from __future__ import annotations

import json
from pathlib import Path
from typing import Any, Dict, List


def build_static_dashboard_html(rows: List[Dict[str, Any]], alerts: List[Dict[str, Any]]) -> str:
    rows_json = json.dumps(rows, ensure_ascii=False)
    alerts_json = json.dumps(alerts, ensure_ascii=False)
    return f"""<!doctype html>
<html lang=\"en\">
<head>
  <meta charset=\"utf-8\" />
  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />
  <title>XDECOW Shark Monitor</title>
  <style>
    body {{ font-family: Arial, sans-serif; margin: 0; background: #07111d; color: #e8f0ff; }}
    .wrap {{ max-width: 1200px; margin: 0 auto; padding: 24px; }}
    .card {{ background: #0d1b2a; border: 1px solid #18314f; border-radius: 16px; padding: 16px; margin-bottom: 16px; }}
    h1, h2 {{ margin: 0 0 12px 0; }}
    table {{ width: 100%; border-collapse: collapse; }}
    th, td {{ padding: 10px; border-bottom: 1px solid #18314f; text-align: left; font-size: 14px; }}
    th {{ color: #9dc4ff; }}
    .pill {{ display: inline-block; padding: 4px 8px; border-radius: 999px; background: #113459; color: #cfe3ff; font-size: 12px; }}
    .muted {{ color: #9ab2ce; font-size: 14px; }}
  </style>
</head>
<body>
  <div class=\"wrap\">
    <div class=\"card\">
      <h1>XDECOW Shark Monitor</h1>
      <div class=\"muted\">Static dashboard generated by GitHub Actions.</div>
    </div>
    <div class=\"card\">
      <h2>Active alerts</h2>
      <div id=\"alerts\"></div>
    </div>
    <div class=\"card\">
      <h2>Market snapshot</h2>
      <table>
        <thead>
          <tr>
            <th>Rank</th>
            <th>Source</th>
            <th>Symbol</th>
            <th>Price</th>
            <th>Change %</th>
            <th>Funding</th>
            <th>Open Interest</th>
            <th>Dist SMA21 %</th>
            <th>Activity Z</th>
            <th>Phi</th>
            <th>Score</th>
          </tr>
        </thead>
        <tbody id=\"rows\"></tbody>
      </table>
    </div>
  </div>
  <script>
    const rows = {rows_json};
    const alerts = {alerts_json};
    const rowsEl = document.getElementById('rows');
    const alertsEl = document.getElementById('alerts');

    rows.forEach((row, idx) => {{
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td>${{idx + 1}}</td>
        <td><span class=\"pill\">${{row.source}}</span></td>
        <td>${{row.symbol}}</td>
        <td>${{Number(row.price || 0).toFixed(4)}}</td>
        <td>${{Number(row.price_change_pct || 0).toFixed(2)}}</td>
        <td>${{Number(row.funding || 0).toFixed(6)}}</td>
        <td>${{Number(row.open_interest || 0).toFixed(2)}}</td>
        <td>${{Number(row.dist_sma21 || 0).toFixed(2)}}</td>
        <td>${{Number(row.activity_zscore || 0).toFixed(2)}}</td>
        <td>${{Number(row.phi_score || 0).toFixed(0)}}</td>
        <td>${{Number(row.score || 0).toFixed(2)}}</td>
      `;
      rowsEl.appendChild(tr);
    }});

    if (!alerts.length) {{
      alertsEl.innerHTML = '<div class="muted">No new alerts in this run.</div>';
    }} else {{
      alertsEl.innerHTML = alerts.map(a => `<div class="muted">${{a.message}} | current=${{a.current}}</div>`).join('');
    }}
  </script>
</body>
</html>
"""


def write_dashboard_files(api_dir: Path, docs_dir: Path, rows: List[Dict[str, Any]], payload: Dict[str, Any], alerts: List[Dict[str, Any]]) -> None:
    api_dir.mkdir(parents=True, exist_ok=True)
    docs_dir.mkdir(parents=True, exist_ok=True)
    (api_dir / "snapshot.json").write_text(json.dumps(payload, indent=2, ensure_ascii=False), encoding="utf-8")
    (api_dir / "alerts.json").write_text(json.dumps(alerts, indent=2, ensure_ascii=False), encoding="utf-8")
    (docs_dir / "index.html").write_text(build_static_dashboard_html(rows, alerts), encoding="utf-8")
